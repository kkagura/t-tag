# API 服务配置
PORT=3000
NODE_ENV=development

# JWT 密钥配置
# ACCESS_TOKEN_SECRET：用于签发访问令牌，生产环境建议至少 32 位高强度随机字符串
ACCESS_TOKEN_SECRET=replace-with-long-access-token-secret
# REFRESH_TOKEN_SECRET：用于刷新令牌校验，生产环境建议至少 32 位高强度随机字符串
REFRESH_TOKEN_SECRET=replace-with-long-refresh-token-secret

# 数据加密密钥（后端 AES-256-GCM 使用）
# 请使用高熵密钥（建议 32 位以上），密钥轮换时需配合数据重加密方案
APP_DATA_ENCRYPTION_KEY=replace-with-strong-encryption-key

# MySQL 5.7 连接配置
# 本地 Docker Compose 示例：
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=t_tag_user
# MYSQL_PASSWORD=t_tag_password
# MYSQL_DATABASE=t_tag_db
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_DATABASE=t_tag
