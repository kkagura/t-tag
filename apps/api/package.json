{
  "name": "@t-tag/api",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:env": "node -r dotenv/config .\\node_modules\\tsx\\dist\\cli.mjs watch src/index.ts dotenv_config_path=.env.%npm_config_env%",
    "dev:development": "npm run dev:env --env=development",
    "dev:production": "npm run dev:env --env=production",
    "build": "tsc -p tsconfig.json",
    "build:env": "node -r dotenv/config .\\node_modules\\typescript\\bin\\tsc -p tsconfig.json dotenv_config_path=.env.%npm_config_env%",
    "build:development": "npm run build:env --env=development",
    "build:production": "npm run build:env --env=production",
    "start": "node dist/index.js",
    "start:env": "node -r dotenv/config dist/index.js dotenv_config_path=.env.%npm_config_env%",
    "start:development": "npm run start:env --env=development",
    "start:production": "npm run start:env --env=production",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "migrate": "tsx src/scripts/migrate.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^13.0.1",
    "@fastify/jwt": "^9.1.0",
    "@fastify/sensible": "^6.0.3",
    "argon2": "^0.44.0",
    "dotenv": "^16.5.0",
    "fastify": "^5.3.3",
    "fastify-plugin": "^5.0.1",
    "mysql2": "^3.15.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.11",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
